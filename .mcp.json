{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--save-trace",
        "--output-dir",
        ".playwright-mcp",
        "--test-id-attribute",
        "data-testid"
      ]
    }
  }
}
