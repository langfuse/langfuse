{
  "servers": {
    "datadog-eu": {
      "type": "http",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp?toolsets=core"
    },
    "datadog-us": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=core"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--save-trace",
        "--output-dir",
        ".playwright-mcp",
        "--test-id-attribute",
        "data-testid"
      ]
    }
  }
}
