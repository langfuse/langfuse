# Test Environment Configuration
# Copy this file to .env.test for test database isolation
# Only overrides specific test variables - other values inherited from .env
# For worktree-specific isolation, run: pnpm run env:worktree

# PostgreSQL - Test Database
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test"
# Optional: isolate by schema within test database
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test?schema=lf_my_worktree_test"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test?schema=lf_my_worktree_test"

# ClickHouse - defaults to .env, optional dedicated test db
# CLICKHOUSE_DB="lf_my_worktree_test"

# Redis - Test Database (database 1 for isolation)
REDIS_CONNECTION_STRING="redis://:myredissecret@127.0.0.1:6379/1"
# REDIS_KEY_PREFIX="lf:test:"
