{
  "name": "@langfuse/skill-index",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src/**"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs",
    "generate:check": "node scripts/generate.mjs --check",
    "build": "tsc",
    "check": "pnpm run generate:check && tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.3.0",
    "prettier": "^3.8.3",
    "ts-morph": "^27.0.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
